// GPU timer text overlay compute shader (Slang)

struct VSOut
{
    float4 position : SV_Position;
};

[shader("vertex")]
VSOut vs_main(uint id : SV_VertexID)
{
    float2 pos[3] = {
        float2(-1.0, -1.0),
        float2( 3.0, -1.0),
        float2(-1.0,  3.0)
    };

    VSOut o;
    o.position = float4(pos[id], 0.0, 1.0);
    return o;
}

[shader("fragment")]
float4 fs_main() : SV_Target0
{
    return float4(0.0, 0.0, 0.0, 1.0);
}

struct TextData
{
    int2 offset;
    int scale;
    uint color;
    uint storageImageId;
    uint data[112 / 4];
};

[[vk::push_constant]]
TextData text;

[[vk::binding(2, 0)]]
RWTexture2D<float4> gStorageImages[];

