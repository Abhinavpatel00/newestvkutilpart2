static uint extractBits(uint value, int offset, int bits)
{
    uint mask = (bits >= 32) ? 0xffffffffu : ((1u << bits) - 1u);
    return (value >> uint(offset)) & mask;
}

static float4 unpackUnorm4x8Manual(uint packed)
{
    float4 c;
    c.x = float((packed >> 0)  & 0xffu) / 255.0;
    c.y = float((packed >> 8)  & 0xffu) / 255.0;
    c.z = float((packed >> 16) & 0xffu) / 255.0;
    c.w = float((packed >> 24) & 0xffu) / 255.0;
    return c;
}

// glyphs are 5x8 pixels; one more line is used for drop shadows
[numthreads(5, 9, 1)]
[shader("compute")]
void cs_main(uint3 dtid : SV_DispatchThreadID,
             uint3 gid  : SV_GroupID,
             uint3 ltid : SV_GroupThreadID)
{
    int2 margin = int2(1, 2);
    int2 size = int2(5, 9) + margin;
    int2 pos = int2(gid.xy) * size + int2(ltid.xy);

    uint ch = extractBits(text.data[gid.x / 4], int(gid.x % 4) * 8, 8);
    uint desc = g_MicroProfileFontDescription[ch / 2];
    uint offset = extractBits(desc, 16 - int(ch % 2) * 16, 16);

    uint u = offset + ltid.x;
    uint v = ltid.y;
    uint texoff = u + 1024u * v;

    uint bit0 = extractBits(g_MicroProfileFont[texoff / 32], 31 - int(texoff % 32), 1);
    uint bit1 = (v == 8u) ? 0u : extractBits(g_MicroProfileFont[(texoff + 1024u) / 32], 31 - int(texoff % 32), 1);

    if((bit0 | bit1) == 0u)
        return;

    float3 color = (bit1 == 1u) ? unpackUnorm4x8Manual(text.color).zyx : float3(0.0, 0.0, 0.0);

    RWTexture2D<float4> outImage = gStorageImages[text.storageImageId];

    for(int y = 0; y < text.scale; ++y)
    {
        for(int x = 0; x < text.scale; ++x)
        {
            int2 p = (text.offset * size + pos) * text.scale + int2(x, y);
            outImage[p] = float4(color, 1.0);
        }
    }
}
