#define NOB_IMPLEMENTATION
#include "external/nob/nob.h"
#include <sys/stat.h>
#include <string.h>
#include <stdio.h>

static void ensure_parent_dir(const char *path)
{
    Nob_String_View sv = nob_sv_from_cstr(path);
    while (1) {
        Nob_String_View part = nob_sv_chop_by_delim(&sv, '/');
        if (sv.count == 0) break;

        const char *dir = nob_temp_sv_to_cstr(part);
        nob_mkdir_if_not_exists(dir);
    }
}

static const char *obj_path_from_src(const char *src)
{
    const char *obj = nob_temp_sprintf("build/%s.o", src);

    // Replace '/' with '_'
    char *mutable = (char*)obj;
    for (size_t i = 0; mutable[i]; ++i) {
        if (mutable[i] == '/')
            mutable[i] = '_';
    }

    return obj;
}

static void append_cpp_from_dir(Nob_File_Paths *out, const char *dir)
{
    Nob_File_Paths entries = {0};
    if (!nob_read_entire_dir(dir, &entries)) {
        fprintf(stderr, "Failed to read dir: %s\n", dir);
        exit(1);
    }

    for (size_t i = 0; i < entries.count; ++i) {
        const char *path = nob_temp_sprintf("%s/%s", dir, entries.items[i]);

        struct stat st;
        if (stat(path, &st) == 0 && S_ISREG(st.st_mode)) {
            Nob_String_View sv = nob_sv_from_cstr(path);
            if (nob_sv_end_with(sv, ".cpp")) {
                nob_da_append(out, path);
            }
        }
    }
}

int main(int argc, char **argv)
{
    NOB_GO_REBUILD_URSELF(argc, argv);

    bool release = false;
    if (argc > 1) {
        if (strcmp(argv[1], "release") == 0) {
            release = true;
        }
    }

    nob_mkdir_if_not_exists("build");

    const char *out = release ? "build/app_release" : "build/app_debug";

    Nob_File_Paths object_files = {0};
    Nob_File_Paths cpp_sources  = {0};

    // -----------------------------
    // Flags
    // -----------------------------

    const char *common_cflags[] = {
        "-std=gnu99",
        "-Wall",
        "-Wextra",
        "-Wpedantic",
    };

    const char *common_cxxflags[] = {
        "-std=gnu++17",
        "-fno-common",
        "-Wall",
        "-Wextra",
        "-Wpedantic",
        "-DIMGUI_IMPL_VULKAN_NO_PROTOTYPES",
        "-DIMGUI_IMPL_API=extern \"C\"",
        "-Iexternal/cimgui",
        "-Iexternal/cimgui/imgui",
        "-Iexternal/cimgui/imgui/backends",
        "-Iexternal/meshoptimizer/src",
    };

    const char *debug_flags[] = { "-ggdb", "-DDEBUG" };
    const char *release_flags[] = { "-O3", "-DNDEBUG" };

    // -----------------------------
    // C sources
    // -----------------------------

    const char *c_sources[] = {
        "main.c",
        "ext.c",
        "vk.c",
        "helpers.c",
        "cachestuff.c",
        "offset_allocator.c",
    };

    for (size_t i = 0; i < NOB_ARRAY_LEN(c_sources); i++) {
        const char *src = c_sources[i];
        const char *obj = obj_path_from_src(src);

        nob_da_append(&object_files, obj);

        const char *inputs[] = { src };
        int rebuild = nob_needs_rebuild(obj, inputs, 1);
        if (rebuild < 0) return 1;
        if (rebuild == 0) {
            printf("[SKIP] %s\n", src);
            continue;
        }

        printf("[BUILD] %s\n", src);

        Nob_Cmd cmd = {0};
        nob_cmd_append(&cmd, "clang", "-c", src, "-o", obj);

        for (size_t j = 0; j < NOB_ARRAY_LEN(common_cflags); j++)
            nob_cmd_append(&cmd, common_cflags[j]);

        const char **mode_flags = release ? release_flags : debug_flags;
        size_t mode_count = release ? NOB_ARRAY_LEN(release_flags)
                                    : NOB_ARRAY_LEN(debug_flags);

        for (size_t j = 0; j < mode_count; j++)
            nob_cmd_append(&cmd, mode_flags[j]);

        if (!nob_cmd_run_sync(cmd))
            return 1;
    }

    // -----------------------------
    // C++ sources (dynamic)
    // -----------------------------

    nob_da_append(&cpp_sources, "vma.cpp");

    append_cpp_from_dir(&cpp_sources, "external/meshoptimizer/src");
    append_cpp_from_dir(&cpp_sources, "external/cimgui");
    append_cpp_from_dir(&cpp_sources, "external/cimgui/imgui");
    append_cpp_from_dir(&cpp_sources, "external/cimgui/imgui/backends");

    for (size_t i = 0; i < cpp_sources.count; i++) {
        const char *src = cpp_sources.items[i];
        const char *obj = obj_path_from_src(src);

        nob_da_append(&object_files, obj);

        const char *inputs[] = { src };
        int rebuild = nob_needs_rebuild(obj, inputs, 1);
        if (rebuild < 0) return 1;
        if (rebuild == 0) {
            printf("[SKIP] %s\n", src);
            continue;
        }

        printf("[BUILD] %s\n", src);

        Nob_Cmd cmd = {0};
        nob_cmd_append(&cmd, "c++", "-c", src, "-o", obj);

        for (size_t j = 0; j < NOB_ARRAY_LEN(common_cxxflags); j++)
            nob_cmd_append(&cmd, common_cxxflags[j]);

        const char **mode_flags = release ? release_flags : debug_flags;
        size_t mode_count = release ? NOB_ARRAY_LEN(release_flags)
                                    : NOB_ARRAY_LEN(debug_flags);

        for (size_t j = 0; j < mode_count; j++)
            nob_cmd_append(&cmd, mode_flags[j]);

        if (!nob_cmd_run_sync(cmd))
            return 1;
    }

    // -----------------------------
    // Linking
    // -----------------------------

    int link_rebuild = nob_needs_rebuild(out, object_files.items, object_files.count);
    if (link_rebuild < 0) return 1;

    if (link_rebuild == 0) {
        printf("[SKIP LINK]\n");
        return 0;
    }

    printf("[LINK] %s\n", out);

    Nob_Cmd cmd = {0};
    nob_cmd_append(&cmd, "c++", "-o", out);

    for (size_t i = 0; i < object_files.count; i++)
        nob_cmd_append(&cmd, object_files.items[i]);

    nob_cmd_append(&cmd,
        "-lvulkan",
        "-lglfw",
        "-ldl",
        "-lpthread",
        "-lm"
    );

    if (!nob_cmd_run_sync(cmd))
        return 1;

    return 0;
}






